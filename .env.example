# .env.example
# Copy this to .env.local and fill in the real values
# DO NOT COMMIT YOUR ACTUAL API KEY TO GITHUB

# Nvidia API Configuration (Optional)
VITE_NVIDIA_API_KEY=your_nvidia_api_key_here
VITE_NVIDIA_MODEL=
VITE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Backend proxy keys (for production Vercel deployment)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_KEYS=key1,key2,key3 # Comma-separated pool for key rotation

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

